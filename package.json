  "version": "0.1.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:og": "node scripts/generate-og-image.mjs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "build:prerender": "node scripts/prerender.mjs",
    "build:full": "npm run build:og && npm run build:sitemap && npm run build && npm run build:prerender",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node --env-file=.env server.js",
    "serve": "node --env-file=.env.local server.js",
